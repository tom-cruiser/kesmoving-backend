# Server Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kesmoving

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRE=30d

# OpenRouter — primary AI provider for image-based time estimation (Qwen VL)
# Get a key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI / Gemini Vision AI (fallback when OPENROUTER_API_KEY is not set)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
AI_PROVIDER=openrouter

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@kesmoving.ca
EMAIL_FROM_NAME=Kesmoving

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# File Upload (Cloudinary or local)
UPLOAD_PROVIDER=local
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# AI Confidence thresholds
AI_CONFIDENCE_THRESHOLD=0.70
